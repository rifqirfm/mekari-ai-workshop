{
	"servers": {
		"com.atlassian/atlassian-mcp-server": {
			"type": "http",
			"url": "https://mcp.atlassian.com/v1/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.1.1"
		},
		"grafana-loki": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run", "--rm", "-i",
				"-e", "LOKI_URL",
				"-e", "LOKI_TOKEN",
				"loki-mcp-server:latest"
			],
			"env": {
				"LOKI_URL": "secret",
				"LOKI_TOKEN": "secret"
			}
		}
	},
	"inputs": []
}